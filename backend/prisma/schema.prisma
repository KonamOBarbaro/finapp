generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  name        String?
  password    String
  income      Float      @default(0) // Used to calculate proportional split
  customSplitPercent Float? // Used when splitRuleMode is CUSTOM
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  ownedAccounts BankAccount[] @relation("UserOwnedAccounts")
  splitsPaid  SplitPayment[] @relation("UserSplits")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  individualExpenses Transaction[] @relation("UserIndividualExpenses")
}

model Workspace {
  id              String           @id @default(uuid())
  name            String
  users           User[]
  bankConnections BankConnection[]
  goals           Goal[]
  budgets         CategoryBudget[]
  investments     Investment[]
  recurring       RecurringExpense[]
  bankAccounts    BankAccount[]
  
  splitRuleMode   String           @default("PROPORTIONAL") // "PROPORTIONAL", "EQUAL", "CUSTOM"
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model BankConnection {
  id           String        @id @default(uuid())
  workspaceId  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  providerName String
  itemId       String        @unique
  bankName     String        
  status       String        
  accounts     BankAccount[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model BankAccount {
  id               String         @id @default(uuid())
  workspaceId      String?
  workspace        Workspace?     @relation(fields: [workspaceId], references: [id])
  bankConnectionId String?
  bankConnection   BankConnection? @relation(fields: [bankConnectionId], references: [id])
  accountId        String         @unique
  name             String
  type             String         // "CHECKING", "CREDIT_CARD", "WALLET", etc
  balance          Float
  currency         String         @default("BRL")
  
  isShared         Boolean        @default(true)
  ownerId          String?
  owner            User?          @relation("UserOwnedAccounts", fields: [ownerId], references: [id])
  
  // Credit Card specific fields
  creditLimit      Float?
  availableLimit   Float?
  dueDate          Int?           // Day of the month (1-31)
  closingDate      Int?           // Day of the month (1-31)

  transactions     Transaction[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Transaction {
  id            String      @id @default(uuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  amount        Float
  description   String
  date          DateTime
  category      String?
  type          String      // "INFLOW", "OUTFLOW"
  paymentMethod String      @default("CASH") // "CASH" (à vista), "INSTALLMENT" (parcelado)
  
  // Installments relation
  installmentId String?
  installment   Installment? @relation(fields: [installmentId], references: [id])
  
  // Individual expenses
  isShared      Boolean     @default(true)
  userId        String?
  user          User?       @relation("UserIndividualExpenses", fields: [userId], references: [id])
  
  // Split logic
  splits        SplitPayment[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Installment {
  id              String        @id @default(uuid())
  totalAmount     Float
  totalInstallments Int
  description     String
  transactions    Transaction[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model SplitPayment {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  userId        String      // The user responsible for this portion
  user          User        @relation("UserSplits", fields: [userId], references: [id])
  amountOwed    Float
  status        String      @default("PENDING") // "PENDING", "PAID"
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// ----------------------------------------------------
// ECOSYSTEM: Advanced Financial Life Features
// ----------------------------------------------------

model Goal {
  id            String      @id @default(uuid())
  workspaceId   String
  workspace     Workspace   @relation(fields: [workspaceId], references: [id])
  name          String      // "Viagem pra Europa", "Carro novo"
  targetAmount  Float
  currentAmount Float       @default(0)
  targetDate    DateTime?
  status        String      @default("ACTIVE") // "ACTIVE", "COMPLETED"
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model CategoryBudget {
  id            String      @id @default(uuid())
  workspaceId   String
  workspace     Workspace   @relation(fields: [workspaceId], references: [id])
  category      String
  amountLimit   Float
  period        String      @default("MONTHLY") // "MONTHLY", "YEARLY"
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([workspaceId, category, period])
}

model Investment {
  id            String      @id @default(uuid())
  workspaceId   String
  workspace     Workspace   @relation(fields: [workspaceId], references: [id])
  name          String      // "CDB Liquidez Diária", "PETR4"
  type          String      // "FIXED_INCOME", "STOCKS", "CRYPTO", "REAL_ESTATE"
  currentValue  Float
  investedAmount Float
  currency      String      @default("BRL")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model RecurringExpense {
  id            String      @id @default(uuid())
  workspaceId   String
  workspace     Workspace   @relation(fields: [workspaceId], references: [id])
  name          String      // "Netflix", "Academia"
  amount        Float
  frequency     String      @default("MONTHLY") // "MONTHLY", "YEARLY"
  nextDueDate   DateTime
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
